# Все текстовые файлы — LF
* text=auto eol=lf

# Явно указываем для каждого типа
*.py   text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.json text eol=lf
*.txt  text eol=lf

# Бинарные файлы — не трогать
*.png  binary
*.jpg  binary
*.gz   binary
*.exe  binary
*.pdf  binary
